# Dependencies
node_modules/

# Build output
dist/
dist-ssr/

# Environment / secrets
.env
.env.*
*.local
# But allow the example file (no secrets, documentation only)
!.env.example
!**/.env.example

# Logs
logs/
*.log
npm-debug.log*

# Editor
.vscode/
.idea/
*.sw?
.DS_Store

# OS
Thumbs.db

# Supabase local
.supabase/

# Lock files (keep package-lock.json, exclude bun)
bun.lockb

# Claude — ignore session/temp files, but keep agents, skills, settings
.claude/*
!.claude/agents/
!.claude/agents/**
!.claude/skills/
!.claude/skills/**
!.claude/settings.json

# --- scripts/ — локальная рабочая папка (клиентские данные, onboard-конфиги, бэкапы) ---
# Whitelist-подход: игнорируем всё, разрешаем только код-утилиты и шаблоны.
# Любые новые .json с клиентскими данными или .md с паролями НЕ попадут в git автоматически.
scripts/*
!scripts/*.ts
!scripts/*.cjs
!scripts/new-client-template.json
!scripts/new-client-template.md
!scripts/README.md

# Old project directories (kept locally as reference, not in repo root)
kamanin-portal/
/tickets/
kamanin-portal-prototype.html
/EXECUTION.md
/SPEC.md
schema.sql

# Allow archived legacy copies inside staging repo
!archive/
!archive/legacy-reference/
!archive/legacy-reference/**

# Debug scripts
debug-clickup-task.cjs
get-clickup-fields.cjs

.vercel
.vite/

# Local-only directories (not for repo)
MBM/
coverage/
screenshots/
supabase/.temp/

# Temp task scripts
tasks/*.js
tasks/session.json

# Root-level ClickUp/DB probe dumps
/_*.json
/_tmp/
/.review/

# Dev seeders с хардкод-секретами
/seed_dev.js
/seed_*.js

# Planning debug dumps (могут содержать access tokens)
.planning/debug/

# Legacy .env в archive
archive/legacy-reference/tickets/.env

# Supabase DB backups
supabase/backups/

# Generated staging artifacts
staging-schema*.sql
.supabase/

# Tool caches and logs
.playwright-mcp/
.superpowers/

# Local backups
portal_backup_*.dump

# Local experiment artifacts (not for repo)
.experiments/
