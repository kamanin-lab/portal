# ============================================================
# Supabase Edge Functions — Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# In production: set these in Coolify → Edge Functions → Environment Variables
# In staging: managed via scripts/sync-staging-secrets.ts
#             (reads from Coolify via SSH, pushes to Cloud Supabase Management API)
#
# NOTE: SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, and SUPABASE_ANON_KEY are
# automatically injected by Cloud Supabase and cannot be set via Management API.
# On self-hosted (Coolify), set them explicitly.

# ---- Supabase ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---- Security Tokens ----
# JWT_SECRET and CRON_SECRET are generated fresh for staging by sync-staging-secrets.ts.
# In production: use strong random values (min 32 bytes).

# Signing key for JWT tokens (self-hosted Supabase).
JWT_SECRET=

# Secret for protecting scheduled/cron Edge Function invocations.
CRON_SECRET=

# ---- ClickUp ----
# Get all ClickUp values from: ClickUp Settings → Apps → API Token / Webhooks

# Personal API token from ClickUp profile settings.
CLICKUP_API_TOKEN=pk_...

# Your ClickUp Workspace ID (numeric). Found in workspace settings URL.
CLICKUP_WORKSPACE_ID=12345678

# Webhook secret configured when registering the ClickUp webhook.
CLICKUP_WEBHOOK_SECRET=

# Custom field IDs — find via ClickUp API: GET /api/v2/list/{listId}/field
# Used for credit balance and task visibility controls in the portal.
CLICKUP_CREDITS_FIELD_ID=
CLICKUP_VISIBLE_FIELD_ID=

# ---- Email (Mailjet) ----
# Get from: https://app.mailjet.com/account/apikeys
MAILJET_API_KEY=
MAILJET_API_SECRET=

# ---- Nextcloud ----
# WebDAV file storage — source of truth for client files.
# NEXTCLOUD_PASS should be an App Password (not your login password).
# Create at: Nextcloud → Settings → Security → App Passwords
NEXTCLOUD_URL=https://cloud.example.com
NEXTCLOUD_USER=service-user
NEXTCLOUD_PASS=app-password

# ---- AI: Anthropic ----
# Used by: fetch-project-tasks (legacy path — now superseded by OpenRouter for most functions)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ---- AI: OpenRouter ----
# Used by: fetch-project-tasks (step enrichment), triage-agent (triage estimation)
# Get from: https://openrouter.ai/keys
# Shared key — no separate key needed for triage-agent vs fetch-project-tasks.
OPENROUTER_API_KEY=sk-or-v1-...

# ---- Triage Agent (Phase 6) ----
# New secrets added in Phase 6 (kmn Triage Agent).
# See docs/agent-setup/triage-agent-setup.md for full setup instructions.

# TRIAGE_ENABLED_LIST_IDS: comma-separated ClickUp list IDs to monitor for triage.
#   The triage-agent only fires for tasks created in these lists.
#   Find a list ID: in ClickUp, open a list → the URL contains /l/{LIST_ID}/
#   Example: https://app.clickup.com/t/901305442177/... → list ID is 901305442177
#   Example value: TRIAGE_ENABLED_LIST_IDS=901305442177,901305442178
TRIAGE_ENABLED_LIST_IDS=

# WP_MCP_USER: WordPress username for Maxi AI Core REST API authentication.
#   Must be a WordPress user with an Application Password configured.
#   The user does not need admin rights — Contributor level is sufficient.
WP_MCP_USER=kamanin-agent

# WP_MCP_APP_PASS: WordPress Application Password for WP_MCP_USER.
#   Generate at: WordPress Admin → Users → {user} → Application Passwords
#   Enter name "KAMANIN Triage Agent" → click "Add New Application Password"
#   Format: "xxxx xxxx xxxx xxxx xxxx xxxx" (spaces included as generated by WordPress)
#   The password is shown only once — copy it immediately.
WP_MCP_APP_PASS=

# ---- Auth / Access ----
# Controls whether Edge Functions verify incoming JWT tokens.
# Set to "true" in production. Can be "false" for local development only.
VERIFY_JWT=true
FUNCTIONS_VERIFY_JWT=true

# Comma-separated email addresses allowed to use project memory management operations.
# Used by manage-project-memory Edge Function. Leave empty if not using this feature.
PROJECT_MEMORY_OPERATOR_EMAILS=

# ---- Auth Email Hook ----
# Points the Supabase auth email hook to the custom auth-email Edge Function.
# In production (self-hosted Coolify): set to self-hosted Supabase Edge Function URL.
# In staging (Cloud Supabase): managed by sync-staging-secrets.ts — points to staging.
# GOTRUE_HOOK_SEND_EMAIL_URI=https://portal.db.kamanin.at/functions/v1/auth-email
GOTRUE_HOOK_SEND_EMAIL_URI=
